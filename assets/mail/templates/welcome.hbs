<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome</title>
  </head>
  <body style="margin: 0; padding: 24px; background: #f3f7ff; font-family: 'Segoe UI', Arial, sans-serif; color: #0f172a;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 620px; margin: 0 auto; background: linear-gradient(145deg, #ffffff 0%, #eef4ff 100%); border-radius: 20px; border: 1px solid #dbeafe; box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08); overflow: hidden;">
      <tr>
        <td style="padding: 28px 28px 10px; text-align: center;">
          <img src="https://res.cloudinary.com/dnpvndlmy/image/upload/q_auto/f_auto/v1775561659/marquill/logo_nwvdon.svg" alt="Marquill" style="width: 160px; max-width: 100%; height: auto;" />
        </td>
      </tr>
      <tr>
        <td style="padding: 12px 28px 8px; text-align: center;">
          <p style="margin: 0; display: inline-block; background: #dbeafe; color: #1d4ed8; font-size: 12px; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; border-radius: 999px; padding: 8px 14px;">
            You are in
          </p>
          <h1 style="margin: 14px 0 10px; font-size: 30px; line-height: 1.2; color: #0b1324;">
            Welcome, {{name}}!
          </h1>
          <p style="margin: 0 auto; max-width: 500px; font-size: 16px; line-height: 1.6; color: #334155;">
            Great to have you on board. Your writing workspace is ready and your next standout post is one click away.
          </p>
        </td>
      </tr>
      {{#if dashboardUrl}}
      <tr>
        <td style="padding: 24px 28px 14px; text-align: center;">
          <a href="{{dashboardUrl}}" style="display: inline-block; background: #1d4ed8; color: #ffffff; text-decoration: none; font-weight: 700; font-size: 15px; border-radius: 12px; padding: 13px 24px;">
            Open Dashboard
          </a>
        </td>
      </tr>
      {{/if}}
      <tr>
        <td style="padding: 10px 28px 28px; text-align: center;">
          <p style="margin: 0; font-size: 13px; color: #64748b;">
            You've got this. We are excited to see what you publish next.
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
