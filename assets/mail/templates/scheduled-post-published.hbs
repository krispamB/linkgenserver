<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Post Published</title>
  </head>
  <body style="margin: 0; padding: 24px; background: #f3f7ff; font-family: 'Segoe UI', Arial, sans-serif; color: #0f172a;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 620px; margin: 0 auto; background: linear-gradient(145deg, #ffffff 0%, #eef4ff 100%); border-radius: 20px; border: 1px solid #dbeafe; box-shadow: 0 10px 25px rgba(15, 23, 42, 0.08); overflow: hidden;">
      <tr>
        <td style="padding: 28px 28px 10px; text-align: center;">
          <img src="https://res.cloudinary.com/dnpvndlmy/image/upload/q_auto/f_auto/v1775561659/marquill/logo_nwvdon.svg" alt="Marquill" style="width: 160px; max-width: 100%; height: auto;" />
        </td>
      </tr>
      <tr>
        <td style="padding: 12px 28px 8px; text-align: center;">
          <p style="margin: 0; display: inline-block; background: #dcfce7; color: #15803d; font-size: 12px; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; border-radius: 999px; padding: 8px 14px;">
            Posted Successfully
          </p>
          <h1 style="margin: 14px 0 10px; font-size: 28px; line-height: 1.2; color: #0b1324;">
            Nice one, {{name}}!
          </h1>
          <p style="margin: 0 auto; max-width: 500px; font-size: 16px; line-height: 1.6; color: #334155;">
            Your scheduled post has just gone live on LinkedIn.
          </p>
        </td>
      </tr>
      <tr>
        <td style="padding: 20px 28px 12px; text-align: center;">
          <div style="display: inline-block; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 12px 16px; font-size: 14px; color: #0f172a;">
            Post ID: <strong>{{postId}}</strong>
          </div>
        </td>
      </tr>
      <tr>
        <td style="padding: 8px 28px 28px; text-align: center;">
          <p style="margin: 0; font-size: 13px; color: #64748b;">
            Keep the momentum going. Your audience is hearing you.
          </p>
        </td>
      </tr>
    </table>
  </body>
</html>
